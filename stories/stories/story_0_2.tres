[gd_resource type="Resource" script_class="Story" format=3 uid="uid://rkuf5ext45pr"]

[ext_resource type="Script" uid="uid://cj3qrux46v0oa" path="res://stories/story.gd" id="1_qqy8f"]
[ext_resource type="Script" uid="uid://daei7gkd11adi" path="res://stories/storyline.gd" id="2_si8l5"]
[ext_resource type="Script" uid="uid://c1f4jfca78fdp" path="res://stories/block/block.gd" id="3_k6jck"]
[ext_resource type="Script" uid="uid://dya03bwq83i4q" path="res://stories/block/dialogue_block.gd" id="4_1x1yy"]
[ext_resource type="Script" uid="uid://b8q4fuillai1a" path="res://stories/block/end_block.gd" id="5_si8l5"]

[sub_resource type="Resource" id="Resource_y2taw"]
script = ExtResource("4_1x1yy")
content = "(14 years ago)"
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_nb6us"]
script = ExtResource("4_1x1yy")
content = "To six-year old you, the world felt too loud and too bright. "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_ficb2"]
script = ExtResource("4_1x1yy")
content = "The class felt like a battlefield. Many kids were running around with their high-pitch screams and the classroom often ended up in a mess."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_fl4fk"]
script = ExtResource("4_1x1yy")
content = "They chased each other with plastic swords or toys, screaming like warriors. Though, for you, you sat in the farthest corner of the room. You didn't like the chaos at all, so you decided to hide behind a tower of wooden blocks."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_cbbax"]
script = ExtResource("4_1x1yy")
content = "You thought that you could hide away from the chaos..."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_omtcu"]
script = ExtResource("4_1x1yy")
content = "Eventually, someone a girl stood in front of you. She was slightly taller than you, hair neatly tied back, and her uniform was extremely tidy. "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_3aiqg"]
script = ExtResource("4_1x1yy")
speaker_enum = 10
content = "Wow, she looked mature"
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_qe23d"]
script = ExtResource("4_1x1yy")
content = "you thought to yourself. "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_1j0jp"]
script = ExtResource("4_1x1yy")
content = "She didn't say anything but rather she pulled a small yellow chair over and placed it directly next to yours. She sat down, smoothen her skirt, and opened a small picture book on her lap."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_rpmc2"]
script = ExtResource("4_1x1yy")
content = "You blinked, confused. "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_csef2"]
script = ExtResource("4_1x1yy")
content = "Your shoulder tensed a bit, then slowly eased when she didn't reached for you to speak up again. In that moment, you felt like your safety circle was breached. "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_aj036"]
script = ExtResource("4_1x1yy")
speaker_enum = 10
content = "\"Soo....uh, why are you sitting here?\""
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_t6727"]
script = ExtResource("4_1x1yy")
content = "you whispered, your voice was barely audible over the chaotic noise of the classroom."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_hfw6a"]
script = ExtResource("4_1x1yy")
content = "She turned a page from her book, avoiding eye contact with you. Her voice was calm, in fact, she lacked the chaotic feeling that was usually found in children their age. "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_djrsn"]
script = ExtResource("4_1x1yy")
speaker_enum = 11
content = "\"Because you looked too pitiful sitting alone. Anyhow, you can call me 梦璃\""
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_4axft"]
script = ExtResource("4_1x1yy")
content = "You flushed. Your grip on your knees tightened and you felt exposed. "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_eb1or"]
script = ExtResource("4_1x1yy")
speaker_enum = 10
content = "\"I'm not pitiful...You can call me 晴...\""
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_nx7v5"]
script = ExtResource("4_1x1yy")
speaker_enum = 11
content = "\"Okay,\""
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_7f0eb"]
script = ExtResource("4_1x1yy")
content = "she said simply. She didn't argue. She didn't leave, either."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_xlfgp"]
script = ExtResource("4_1x1yy")
content = "She just stayed."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_bnkcn"]
script = ExtResource("4_1x1yy")
content = "She read her book, and you sat behind your block tower. For whatever reason, her silent presence felt comforting "
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_k6jck"]
script = ExtResource("5_si8l5")
metadata/_custom_type_script = "uid://b8q4fuillai1a"

