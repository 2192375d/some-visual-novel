[sub_resource type="Resource" id="Resource_atb6k"]
script = ExtResource("4_tewpv")
content = "Memory is like a liar, it paints the past with gold."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_8o2vy"]
script = ExtResource("4_tewpv")
content = "It turns a regular sunset into a blazing fire and a simple smile into a salvation."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_1udhf"]
script = ExtResource("4_tewpv")
content = "But, in your memory of her, the colors were real. Only the sound was distorted. You could never quite remember the exact pitch of her voice...only the promises she made."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

[sub_resource type="Resource" id="Resource_8a2li"]
script = ExtResource("4_tewpv")
content = "You remember that silence with her was never empty. It was the only time you felt safe."
metadata/_custom_type_script = "uid://dya03bwq83i4q"

